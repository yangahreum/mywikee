# Supabase (자신의 프로젝트 값으로 채우고 .env.local 로 복사)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# source 생성(HTML 파일 쓰기) 대상 LLM-Wiki 볼트 루트.
# 설정되지 않으면 export 라우트는 비활성(글은 DB 에 그대로 보존).
WIKI_ROOT="/Users/areumyang/AI/wiki"

# ── 인증 e2e(playwright) 전용 ────────────────────────────────────────────
# 인증 후 홈(/) 스모크를 돌리려면 password 로그인 가능한 테스트 유저가 필요하다.
# 앱 자체는 매직링크(OTP)만 쓰지만, e2e setup 은 signInWithPassword 로 세션을
# 직접 얻어 storageState 로 주입한다. Supabase 대시보드에서 이메일/비번 유저를
# 하나 만들어(또는 Auth > Users 에서 password 설정) 아래에 채운다.
# 이 두 값이 없으면 인증 e2e(setup)는 실패한다(미인증 스모크는 영향 없음).
E2E_TEST_EMAIL="e2e-test-user@example.com"
E2E_TEST_PASSWORD="your-test-user-password"
